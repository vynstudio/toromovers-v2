# Toro Movers v2 — env var reference.
#
# Copy to .env.local for local dev (gitignored by Next.js's default .gitignore).
# Paste each KEY=VALUE into Vercel → Project Settings → Environment Variables.
#
# Setting a value to "PLACEHOLDER" is treated as missing — the site still
# deploys, but the gated feature (email send, pixel fire, GA tracking) becomes
# a no-op until a real value is set. See src/lib/env.ts.

# --- Server-only (Resend lead notification) ---
RESEND_API_KEY=PLACEHOLDER
LEAD_NOTIFICATION_EMAIL=dilerbizz@gmail.com
LEAD_FROM_EMAIL=onboarding@resend.dev

# --- Public (NEXT_PUBLIC_* are inlined into the client bundle at build time) ---
NEXT_PUBLIC_META_PIXEL_ID=PLACEHOLDER
NEXT_PUBLIC_GA_MEASUREMENT_ID=PLACEHOLDER
NEXT_PUBLIC_GADS_CONVERSION_ID=PLACEHOLDER
NEXT_PUBLIC_GADS_CONVERSION_LABEL=PLACEHOLDER
